[gd_scene format=3]

[node name="MapTab" type="VBoxContainer"]
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 16

[node name="TitleLabel" type="Label" parent="."]
layout_mode = 2
theme_override_font_sizes/font_size = 26
text = "Map"

[node name="ChapterLabel" type="Label" parent="."]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Chapter 1"

[node name="CurrentStateLabel" type="Label" parent="."]
layout_mode = 2
autowrap_mode = 3
theme_override_font_sizes/font_size = 20
text = "Current: Wave 1"

[node name="ClearedChaptersLabel" type="Label" parent="."]
layout_mode = 2
autowrap_mode = 3
theme_override_font_sizes/font_size = 20
text = "Cleared Chapters: 0"

[node name="AutoSummaryLabel" type="Label" parent="."]
layout_mode = 2
autowrap_mode = 3
theme_override_font_sizes/font_size = 18
text = "Auto Next Wave: ON | Auto Start Boss: OFF"

[node name="WaveGrid" type="GridContainer" parent="."]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 10
theme_override_constants/v_separation = 10
columns = 5

[node name="Wave1Button" type="Button" parent="WaveGrid"]
custom_minimum_size = Vector2(0, 88)
layout_mode = 2
size_flags_horizontal = 3
text = "Wave 1"
toggle_mode = true

[node name="Wave2Button" type="Button" parent="WaveGrid"]
custom_minimum_size = Vector2(0, 88)
layout_mode = 2
size_flags_horizontal = 3
text = "Wave 2"
toggle_mode = true

