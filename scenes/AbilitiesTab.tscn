theme_override_constants/v_separation = 10

[node name="PopupOverlay" type="ColorRect" parent="."]
visible = false
layout_mode = 2
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
color = Color(0, 0, 0, 0.55)

[node name="PopupPanel" type="PanelContainer" parent="PopupOverlay"]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -320.0
offset_top = -220.0
offset_right = 320.0
offset_bottom = 220.0
grow_horizontal = 2
grow_vertical = 2

[node name="PopupMargin" type="MarginContainer" parent="PopupOverlay/PopupPanel"]
layout_mode = 2
